// Generación del cliente de Prisma para poder usarlo en nuestro código JavaScript
generator cliente {
  provider = "prisma-client-js"
}

// Configuración de la conexión a la base de datos PostgreSQL
// La URL de conexión se guarda de forma segura en el archivo .env
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELOS DE LA APLICACIÓN ---

// Tabla que guarda la información principal de las personas que usan la app
model usuarios {
  id               Int                @id @default(autoincrement())
  nombre_usuario   String             @unique @db.VarChar(50)
  correo           String             @unique @db.VarChar(100)
  contrasena_hash  String             // La contraseña se guarda encriptada por seguridad
  puntos_experiencia Int?             @default(0) // Puntos acumulados para el sistema de rangos
  fecha_registro   DateTime?          @default(now()) @db.Timestamp(6)
  
  // Relaciones: Un usuario tiene sus propios hábitos, entradas de diario y sesiones de meditación
  entradas_diario      entradas_diario[]
  habitos              habitos[]
  sesiones_meditacion  sesiones_meditacion[]
}

// Tabla para el seguimiento emocional y notas del día a día
model entradas_diario {
  id              Int          @id @default(autoincrement())
  usuario_id      Int?
  fecha           DateTime?    @default(dbgenerated("CURRENT_DATE")) @db.Date
  puntuacion_animo Int?        // Valor numérico para saber cómo se sentía el usuario
  horas_sueno     Decimal?     @db.Decimal(4, 2)
  contenido_texto String?      // Espacio para que el usuario escriba sus reflexiones
  
  // Conexiones con otras tablas
  usuario         usuarios?    @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  archivos_multimedia multimedia[]

  // Evita que un usuario cree dos entradas para el mismo día
  @@unique([usuario_id, fecha])
}

// Tabla para definir qué hábitos quiere mejorar el usuario
model habitos {
  id              Int                 @id @default(autoincrement())
  usuario_id      Int?
  nombre          String              @db.VarChar(100)
  categoria       String?             @db.VarChar(50) // Ejemplo: Salud, Trabajo, Deporte
  icono           String?             @db.VarChar(50) // Nombre del dibujo que se mostrará
  esta_activo     Boolean?            @default(true)  // Si el hábito sigue vigente o se ha pausado
  fecha_creacion  DateTime?           @default(dbgenerated("CURRENT_DATE")) @db.Date
  
  usuario         usuarios?           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  registros_cumplimiento registros_habitos[]
}

// Tabla que registra qué días se ha cumplido cada hábito
model registros_habitos {
  id              Int      @id @default(autoincrement())
  habito_id       Int?
  fecha           DateTime @db.Date
  fue_completado  Boolean? @default(false) // Indica si el usuario cumplió el hábito ese día
  
  habito          habitos? @relation(fields: [habito_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // No permite duplicar el registro de un mismo hábito en la misma fecha
  @@unique([habito_id, fecha])
}

// Tabla para gestionar los niveles y rangos según la experiencia ganada
model rangos_referencia {
  id           Int     @id @default(autoincrement())
  nombre_rango String  @db.VarChar(50) // Ejemplo: "Novato", "Maestro"
  xp_minima    Int     // Cuántos puntos necesitas para alcanzar este rango
  ruta_icono   String? // Imagen del emblema del rango
}

// Tabla para guardar enlaces a fotos o archivos subidos en el diario
model multimedia {
  id              Int              @id @default(autoincrement())
  entrada_id      Int?
  tipo_archivo    String?          @db.VarChar(10) // Ejemplo: jpg, png, mp4
  url_archivo     String           // Dirección donde está guardado el archivo
  entrada_diario  entradas_diario? @relation(fields: [entrada_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

// Tabla para registrar las sesiones de meditación completadas por el usuario
model sesiones_meditacion {
  id                    Int      @id @default(autoincrement())
  usuario_id            Int
  duracion_segundos     Int      // Duración total configurada de la sesión (en segundos)
  segundos_completados  Int      // Segundos realmente meditados antes de finalizar
  tecnica_respiracion   String   @db.VarChar(50) // Ejemplo: 'equilibrio', 'cuadrada', 'relajacion'
  pista_musica          String?  @db.VarChar(50) // Pista de música ambiental usada (null si no se usó)
  fecha                 DateTime @default(now()) @db.Timestamp(6) // Momento exacto en que finalizó la sesión

  usuario               usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}