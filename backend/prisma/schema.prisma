generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model entradas_diario {
  id              Int          @id @default(autoincrement())
  usuario_id      Int?
  fecha           DateTime?    @default(dbgenerated("CURRENT_DATE")) @db.Date
  mood_score      Int?
  horas_sueno     Decimal?     @db.Decimal(4, 2)
  contenido_texto String?
  usuarios        usuarios?    @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  multimedia      multimedia[]

  @@unique([usuario_id, fecha])
}

model habitos {
  id                Int                 @id @default(autoincrement())
  usuario_id        Int?
  nombre            String              @db.VarChar(100)
  categoria         String?             @db.VarChar(50)
  icono             String?             @db.VarChar(50)
  activo            Boolean?            @default(true)
  fecha_creacion    DateTime?           @default(dbgenerated("CURRENT_DATE")) @db.Date
  usuarios          usuarios?           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  registros_habitos registros_habitos[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model multimedia {
  id              Int              @id @default(autoincrement())
  entrada_id      Int?
  tipo_archivo    String?          @db.VarChar(10)
  url_archivo     String
  entradas_diario entradas_diario? @relation(fields: [entrada_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model rangos_referencia {
  id           Int     @id @default(autoincrement())
  nombre_rango String  @db.VarChar(50)
  xp_minima    Int
  icono_ruta   String?
}

model registros_habitos {
  id         Int      @id @default(autoincrement())
  habito_id  Int?
  fecha      DateTime @db.Date
  completado Boolean? @default(false)
  habitos    habitos? @relation(fields: [habito_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([habito_id, fecha])
}

model usuarios {
  id              Int               @id @default(autoincrement())
  username        String            @unique @db.VarChar(50)
  email           String            @unique @db.VarChar(100)
  password_hash   String
  puntos_xp       Int?              @default(0)
  fecha_registro  DateTime?         @default(now()) @db.Timestamp(6)
  entradas_diario entradas_diario[]
  habitos         habitos[]
}
